# ╔══════════════════════════════════════════════════════════════╗
# ║               OMNI DUCK — ENVIRONMENT VARIABLES              ║
# ║               OMNI DUCK — BIẾN MÔI TRƯỜNG (MẪU)             ║
# ║         Sao chép thành .env  |  English: .env.example.en    ║
# ║              KHÔNG commit file .env lên git                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ╔══════════════════════════════════════════════════════════════╗
# ║            ỨNG DỤNG / CƠ SỞ DỮ LIỆU / TUNNEL                 ║
# ╚══════════════════════════════════════════════════════════════╝
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/omniduck

# ┌─ Ngrok (3 biến — đồng bộ cùng 1 domain) ─────────────────────┐
# │ NGROK_DOMAIN      → chỉ cho npm run dev:tunnel                │
# │ VITE_API_BASE_URL → frontend gọi backend                      │
# │ WEBHOOK_BASE_URL  → Telegram webhook / callback ngoài           │
# │                                                               │
# │ Chạy thủ công: npx ngrok http 3001 --url=<domain>              │
# │ Hoặc npm:      npm run dev:tunnel                             │
# └───────────────────────────────────────────────────────────────┘
NGROK_DOMAIN=your-name.ngrok-free.dev
VITE_API_BASE_URL=https://your-name.ngrok-free.dev
WEBHOOK_BASE_URL=https://your-name.ngrok-free.dev

APP_URL=http://localhost:3001
AI_REPORT_CACHE_TTL_MS=5400000

# Node.js 24+ Windows: nếu lỗi SSL MongoDB, chạy với node --use-system-ca
# (npm run dev:backend đã cấu hình sẵn)

# ╔══════════════════════════════════════════════════════════════╗
# ║                      ADMIN / BẢO MẬT                         ║
# ╚══════════════════════════════════════════════════════════════╝
# Bảo vệ endpoint reset AI provider (để trống = không cần key khi dev local)
ADMIN_RESET_KEY=your_admin_reset_key

# Mã admin cho các route nhạy cảm (audit-file-tail, ...)
ADMIN_CODE=your_admin_code_here

# Secret cho webhook external signal (POST /api/external-signal)
EXTERNAL_SIGNAL_SECRET=your_strong_secret_here

# 64 ký tự hex (= 32 bytes) cho AES-256-GCM
# Dùng mã hóa API key exchange của user + audit log (nếu bật)
# Sinh key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ╔══════════════════════════════════════════════════════════════╗
# ║                     NHÀ CUNG CẤP AI                          ║
# ╚══════════════════════════════════════════════════════════════╝
# Chuỗi fallback Gemini: GEMINI_API_KEY_MAIN -> GEMINI_API_KEY -> API_KEY
GEMINI_API_KEY_MAIN=AIza...
GEMINI_API_KEY_ACTION=
GEMINI_API_KEY_INSIGHT=

MISTRAL_API_KEY=
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk-...
SAMBANOVA_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-...
DEEPINFRA_API_KEY=

# Tùy chọn — DS2API local (không khuyến nghị production)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=http://127.0.0.1:5001/v1

# ╔══════════════════════════════════════════════════════════════╗
# ║                    DỮ LIỆU THỊ TRƯỜNG                      ║
# ╚══════════════════════════════════════════════════════════════╝
COINGECKO_API_KEY=
COINGLASS_API_KEY=
FIREANT_TOKEN=your_fireant_token_here

# ╔══════════════════════════════════════════════════════════════╗
# ║                         TELEGRAM                             ║
# ╚══════════════════════════════════════════════════════════════╝
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ╔══════════════════════════════════════════════════════════════╗
# ║          FRONTEND (Vite — đọc qua import.meta.env)           ║
# ╚══════════════════════════════════════════════════════════════╝
VITE_AI_PRICE_SIGNIFICANT_THRESHOLD=0.015
VITE_AI_NEWS_SIGNIFICANT_COUNT_THRESHOLD=3

# ╔══════════════════════════════════════════════════════════════╗
# ║               GIỚI HẠN AN TOÀN SÀN GIAO DỊCH                 ║
# ╚══════════════════════════════════════════════════════════════╝
MAX_LIVE_ORDER_VALUE_USDT=10000
MAX_LIVE_ORDERS_PER_USER=5

# ╔══════════════════════════════════════════════════════════════╗
# ║        VN STOCK — PREFETCH TIN TỨC (cron + cache tab)       ║
# ╚══════════════════════════════════════════════════════════════╝
# Cron nền lấy headline + sentiment cho ~60 mã universe AutoDuck.
# Phục vụ: tab phân tích VN mở nhanh + AutoDuck đọc deepNewsData sẵn.
# Chỉ fetch nhẹ (fast mode, không cào full bài) để tránh rate-limit Google/RSS.
# Lịch: 30 phút (T2–T6) · 6 giờ (T7/CN). Tab user: ?force=true để ép fetch lại.

# Bật/tắt toàn bộ cron prefetch (đặt false để tắt)
VN_NEWS_PREFETCH_ENABLED=true

# TTL cache tin trong DB — khi còn fresh, /api/news/:ticker trả ngay từ DB
# Trong phiên VN: Pre-market, ATO, giờ khớp, ATC (ms). Mặc định 1 giờ.
VN_NEWS_CACHE_TTL_SESSION_MS=3600000
# Ngoài phiên + cuối tuần (ms). Mặc định 6 giờ.
VN_NEWS_CACHE_TTL_OFF_MS=21600000

# Giới hạn tải mỗi lượt cron (stagger — tránh burst IP/limit)
VN_NEWS_PREFETCH_MAX_PER_RUN=10
VN_NEWS_PREFETCH_CONCURRENCY=2
VN_NEWS_PREFETCH_DELAY_MS=4000
# Số mã universe (cùng nguồn buildVnStockScanUniverse với AutoDuck)
VN_NEWS_PREFETCH_UNIVERSE_LIMIT=60

# ╔══════════════════════════════════════════════════════════════╗
# ║              AUTODUCK — IDLE / QUÉT / THĂM DÒ               ║
# ╚══════════════════════════════════════════════════════════════╝
AUTODUCK_IDLE_FAST_SCAN_MS=180000
AUTODUCK_IDLE_RELAX_TARGETS=1,3,5
AUTODUCK_IDLE_RELAX_STEP_SCORE=3
AUTODUCK_IDLE_RELAX_MAX_SCORE=6
AUTODUCK_IDLE_RELAX_MAX_ATTEMPTS=4
AUTODUCK_IDLE_MIN_SIM_SCORE=68
AUTODUCK_IDLE_MIN_LIVE_SCORE=80

# Khi true: nếu bot "đói lệnh" và AI chỉ veto lý do mềm, có thể cho vào lệnh thăm dò
AUTODUCK_IDLE_AI_PROBE_ENABLED=false
AUTODUCK_IDLE_AI_PROBE_MIN_SCORE=78
AUTODUCK_IDLE_AI_PROBE_SIZE_MULT=0.45

# true = idle probe có thể đi LIVE (nên false để an toàn)
AUTODUCK_IDLE_AI_PROBE_LIVE=false

# ╔══════════════════════════════════════════════════════════════╗
# ║           AUTODUCK — BỐI CẢNH / BIAS / CHẤT LƯỢNG            ║
# ╚══════════════════════════════════════════════════════════════╝
# Ảnh hưởng tâm lý thị trường VN lên quyết định crypto (0 = tách biệt hơn)
AUTODUCK_CRYPTO_VN_BREADTH_BLEND=0.08
AUTODUCK_CRYPTO_VN_CROSS_BIAS=true
AUTODUCK_CONTEXT_BIAS_MAX=6

AUTODUCK_LIVE_QUALITY_MIN=82
AUTODUCK_SIM_QUALITY_MIN=72
AUTODUCK_LIVE_CONFLUENCE_MIN=3
AUTODUCK_LIVE_EDGE_MIN=28

# Chất lượng theo setup (mặc định = AUTODUCK_LIVE_QUALITY_MIN nếu không set)
# AUTODUCK_LIVE_MIN_QUALITY_EMA_PULLBACK=80
# AUTODUCK_LIVE_MIN_QUALITY_VWAP_RECLAIM=82

# ╔══════════════════════════════════════════════════════════════╗
# ║              AUTODUCK — SHORT LIVE / POLL FILL               ║
# ╚══════════════════════════════════════════════════════════════╝
# Cho phép setup SHORT_CONTINUATION vào LIVE whitelist (không phải "macro short liên tục")
AUTODUCK_LIVE_ALLOW_SHORT_CONTINUATION=false
AUTODUCK_LIVE_ALLOW_SHORT_FALLBACK=false
# AUTODUCK_LIVE_MIN_QUALITY_SHORT_CONTINUATION=82
# AUTODUCK_LIVE_MIN_QUALITY_SHORT=84

# Fallback nếu DB Setting chưa có autoFuturesShortEnabled
AUTODUCK_AUTO_FUTURES_SHORT_ENABLED=false

AUTODUCK_LIVE_FILL_POLL_MS=2000
AUTODUCK_LIVE_FILL_TIMEOUT_MS=25000

# ╔══════════════════════════════════════════════════════════════╗
# ║                   AUTODUCK — LOG AUDIT                       ║
# ╚══════════════════════════════════════════════════════════════╝
AUTODUCK_AUDIT_ENABLED=true
AUTODUCK_AUDIT_LOG_DIR=logs/autoduck
AUTODUCK_AUDIT_ENCRYPT=false
# Nếu AUTODUCK_AUDIT_ENCRYPT=true: dùng key này (64 hex) hoặc fallback ENCRYPTION_KEY
# AUTODUCK_AUDIT_ENCRYPTION_KEY=

# Cache symbol testnet từ exchangeInfo (ms), 21600000 = 6 giờ
TESTNET_SYMBOL_CACHE_MS=21600000
