# ╔══════════════════════════════════════════════════════════════╗
# ║               OMNI DUCK — ENVIRONMENT VARIABLES              ║
# ║               OMNI DUCK — BIẾN MÔI TRƯỜNG                    ║
# ║                    (Root .env file)                          ║
# ╚══════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🎯 REQUIRED — Main AI & Database / BẮT BUỘC — AI Chính & Cơ sở dữ liệu
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Gemini — Main key for analysis, streaming, reporting
# Gemini — Khóa chính dùng cho phân tích, luồng dữ liệu, báo cáo
# Fallback chain: GEMINI_API_KEY_MAIN → GEMINI_API_KEY → API_KEY
GEMINI_API_KEY_MAIN=AIza...

# Gemini — Private key for action/JSON tasks (optional, reuse main key if left blank)
# Gemini — Khóa phụ dùng cho các tác vụ action/JSON (Tùy chọn, để trống sẽ dùng khóa chính)
GEMINI_API_KEY_ACTION=

# MongoDB URI (get on official website of MongoDB)
# MongoDB (Lấy từ trang web chính thức của MongoDB)
# Local: mongodb://localhost:27017/omniduck
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/xxx
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/omniduck...
# TUNNELING 
NGROK_DOMAIN= .....dev.ngrok-free.app


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🤖 AI PROVIDERS — Fallback chain / NHÀ CUNG CẤP AI — Chuỗi dự phòng
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Groq — Fast inference, role: tech / bull / pm / chat / crypto
# Groq — Tốc độ xử lý nhanh, vai trò: tech / bull / pm / chat / crypto
# Free tier / Gói miễn phí: https://console.groq.com
GROQ_API_KEY=gsk_...

# Cerebras — Strong reasoning, role: fundamental / bear
# Cerebras — Khả năng suy luận mạnh, vai trò: fundamental / bear
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...

# SambaNova — Long context, role: news / sentiment
# SambaNova — Context dài, vai trò: news / sentiment
# https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# DeepInfra — Secondary fallback for news role
# DeepInfra — Dự phòng phụ cho vai trò news
# https://deepinfra.com
DEEPINFRA_API_KEY=

# OpenRouter — Final fallback for bull role
# OpenRouter — Dự phòng cuối cùng cho vai trò bull
# https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# URL to send Referer header when calling OpenRouter (default: http://localhost:3001)
# URL để gửi header Referer khi gọi OpenRouter (Mặc định: http://localhost:3001)
APP_URL=http://localhost:3001

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📰 NEWS & SOCIAL DATA / TIN TỨC & DỮ LIỆU MẠNG XÃ HỘI
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# FireAnt — Social sentiment for VN stocks
# FireAnt — Đánh giá tâm lý mạng xã hội cho cổ phiếu VN
# Get your token from: https://fireant.vn (login → DevTools → tab Network -> Headers -> Authorization: Bearer <token>)
# Lấy token từ: https://fireant.vn (Đăng nhập → DevTools → tab Network -> Headers -> Authorization: Bearer <token>)
FIREANT_TOKEN=your_fireant_token_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🪙 CRYPTOCURRENCY / TIỀN ĐIỆN TỬ
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CoinGlass — Liquidation data for crypto derivatives (optional)
# CoinGlass — Dữ liệu thanh lý cho phái sinh crypto (Tùy chọn)
# https://coinglass.com/pricing
COINGLASS_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔔 TELEGRAM - Important / Quan trọng
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Bot token (create at t.me/BotFather)
# Token của Bot (Tạo tại t.me/BotFather)
# Fallback chain: TELEGRAM_BOT_TOKEN → TELEGRAM_TOKEN
TELEGRAM_BOT_TOKEN=your_bot_token

# Chat ID to receive system alerts (AI provider downtime, rate limit, etc.)
# Chat ID để nhận các cảnh báo hệ thống (AI down, rate limit, v.v.)
# Fallback chain: TELEGRAM_CHAT_ID → TELEGRAM_CHANNEL_ID
TELEGRAM_CHAT_ID=your_chat_id

# Private chat ID for admin (used for route /api/telegram)
# Private chat ID dành riêng cho admin (Dùng cho route /api/telegram)
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# Webhook base URL for Telegram bot (optional, used with ngrok for local dev)
# Webhook base URL cho Telegram bot (Tùy chọn, thường dùng với ngrok khi dev local)
WEBHOOK_BASE_URL=https://your-ngrok-domain.ngrok-free.app

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔐 SECURITY / BẢO MẬT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Secret for external signal webhook (POST /api/external-signal)
# Secret key cho webhook nhận tín hiệu bên ngoài (POST /api/external-signal)
# Default: 'default-secret-key-please-change' — SHOULD be changed in production / BẮT BUỘC đổi trên môi trường production
EXTERNAL_SIGNAL_SECRET=your_strong_secret_here

# Key to call admin reset endpoint
# Key để gọi endpoint reset của admin
ADMIN_RESET_KEY=your_admin_reset_key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚡ PERFORMANCE / HIỆU SUẤT (customizable, with defaults / Có thể tùy chỉnh, có giá trị mặc định)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# TTL cache for AI report (ms). Default: 900000 (15 minutes)
# Thời gian sống (TTL) của cache báo cáo AI (tính bằng ms). Mặc định: 900000 (15 phút)
AI_REPORT_CACHE_TTL_MS=900000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌐 FRONTEND (Vite — read via import.meta.env / đọc qua import.meta.env)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Base URL backend (Vite proxy handles /api → localhost:3001)
# Base URL của backend (Vite proxy sẽ điều hướng /api → localhost:3001)
VITE_API_BASE_URL=http://localhost:3001

# Price fluctuation threshold to trigger AI Active (optional, default: 0.015 = 1.5%)
# Ngưỡng biến động giá để kích hoạt AI tự động (Tùy chọn, mặc định: 0.015 tương đương 1.5%)
VITE_AI_PRICE_SIGNIFICANT_THRESHOLD=0.015

# Minimum number of news items to trigger AI automatically (optional, default: 3)
# Số lượng tin tức tối thiểu để kích hoạt AI tự động (Tùy chọn, mặc định: 3)
VITE_AI_NEWS_SIGNIFICANT_COUNT_THRESHOLD=3
ADMIN_CODE=your_admin_code_here