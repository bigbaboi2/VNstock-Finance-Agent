# ╔══════════════════════════════════════════════════════════════╗
# ║               OMNI DUCK — ENVIRONMENT VARIABLES              ║
# ║                    (Template / .env.example.en)              ║
# ║              Vietnamese version: .env.example                ║
# ║                  DO NOT commit .env to git                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ╔══════════════════════════════════════════════════════════════╗
# ║                  APP / DATABASE / TUNNEL                     ║
# ╚══════════════════════════════════════════════════════════════╝
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/omniduck

# ┌─ Ngrok (3 vars — keep the SAME domain) ──────────────────────┐
# │ NGROK_DOMAIN      → only for npm run dev:tunnel               │
# │ VITE_API_BASE_URL → frontend calls backend                    │
# │ WEBHOOK_BASE_URL  → Telegram webhooks / external callbacks    │
# │                                                               │
# │ Manual:  npx ngrok http 3001 --url=<domain>                     │
# │ Or npm:  npm run dev:tunnel                                   │
# └───────────────────────────────────────────────────────────────┘
NGROK_DOMAIN=your-name.ngrok-free.dev
VITE_API_BASE_URL=https://your-name.ngrok-free.dev
WEBHOOK_BASE_URL=https://your-name.ngrok-free.dev

APP_URL=http://localhost:3001
AI_REPORT_CACHE_TTL_MS=5400000

# Node.js 24+ on Windows: if MongoDB SSL fails, use node --use-system-ca
# (npm run dev:backend is already configured)

# ╔══════════════════════════════════════════════════════════════╗
# ║                      ADMIN / SECURITY                        ║
# ╚══════════════════════════════════════════════════════════════╝
# Protects AI provider reset endpoint (blank = no key needed for local dev)
ADMIN_RESET_KEY=your_admin_reset_key

# Admin code for sensitive routes (audit-file-tail, ...)
ADMIN_CODE=your_admin_code_here

# Secret for external signal webhook (POST /api/external-signal)
EXTERNAL_SIGNAL_SECRET=your_strong_secret_here

# 64 hex chars (= 32 bytes) for AES-256-GCM
# Encrypts user exchange API keys + audit logs (when enabled)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ╔══════════════════════════════════════════════════════════════╗
# ║                       AI PROVIDERS                           ║
# ╚══════════════════════════════════════════════════════════════╝
# Gemini fallback chain: GEMINI_API_KEY_MAIN -> GEMINI_API_KEY -> API_KEY
GEMINI_API_KEY_MAIN=AIza...
GEMINI_API_KEY_ACTION=
GEMINI_API_KEY_INSIGHT=

MISTRAL_API_KEY=
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk-...
SAMBANOVA_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-...
DEEPINFRA_API_KEY=

# Optional — local DS2API (not recommended for production)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=http://127.0.0.1:5001/v1

# ╔══════════════════════════════════════════════════════════════╗
# ║                    MARKET DATA PROVIDERS                     ║
# ╚══════════════════════════════════════════════════════════════╝
COINGECKO_API_KEY=
COINGLASS_API_KEY=
FIREANT_TOKEN=your_fireant_token_here

# ╔══════════════════════════════════════════════════════════════╗
# ║                         TELEGRAM                             ║
# ╚══════════════════════════════════════════════════════════════╝
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ╔══════════════════════════════════════════════════════════════╗
# ║            FRONTEND (Vite — read via import.meta.env)        ║
# ╚══════════════════════════════════════════════════════════════╝
VITE_AI_PRICE_SIGNIFICANT_THRESHOLD=0.015
VITE_AI_NEWS_SIGNIFICANT_COUNT_THRESHOLD=3

# ╔══════════════════════════════════════════════════════════════╗
# ║                   EXCHANGE SAFETY GUARDS                     ║
# ╚══════════════════════════════════════════════════════════════╝
MAX_LIVE_ORDER_VALUE_USDT=10000
MAX_LIVE_ORDERS_PER_USER=5

# ╔══════════════════════════════════════════════════════════════╗
# ║        VN STOCK — NEWS PREFETCH (cron + tab cache)           ║
# ╚══════════════════════════════════════════════════════════════╝
# Background cron fetches headlines + sentiment for ~60 AutoDuck universe symbols.
# Speeds up VN analysis tab + keeps deepNewsData warm for AutoDuck.
# Lightweight fetch only (fast mode, no full article scrape) to avoid Google/RSS rate limits.
# Schedule: every 30 min (Mon–Fri) · every 6 h (Sat–Sun). Force refresh: ?force=true on /api/news/:ticker

# Enable/disable prefetch cron (set false to turn off)
VN_NEWS_PREFETCH_ENABLED=true

# DB news cache TTL — while fresh, /api/news/:ticker serves from DB immediately
# VN session: pre-market, ATO, regular hours, ATC (ms). Default 1 hour.
VN_NEWS_CACHE_TTL_SESSION_MS=3600000
# Off-session + weekends (ms). Default 6 hours.
VN_NEWS_CACHE_TTL_OFF_MS=21600000

# Per cron run limits (staggered to avoid burst / IP blocks)
VN_NEWS_PREFETCH_MAX_PER_RUN=10
VN_NEWS_PREFETCH_CONCURRENCY=2
VN_NEWS_PREFETCH_DELAY_MS=4000
# Universe size (same buildVnStockScanUniverse source as AutoDuck)
VN_NEWS_PREFETCH_UNIVERSE_LIMIT=60

# ╔══════════════════════════════════════════════════════════════╗
# ║               AUTODUCK — IDLE / SCAN / PROBE                 ║
# ╚══════════════════════════════════════════════════════════════╝
AUTODUCK_IDLE_FAST_SCAN_MS=180000
AUTODUCK_IDLE_RELAX_TARGETS=1,3,5
AUTODUCK_IDLE_RELAX_STEP_SCORE=3
AUTODUCK_IDLE_RELAX_MAX_SCORE=6
AUTODUCK_IDLE_RELAX_MAX_ATTEMPTS=4
AUTODUCK_IDLE_MIN_SIM_SCORE=68
AUTODUCK_IDLE_MIN_LIVE_SCORE=80

# When true: if bot is "hungry" and AI only soft-vetoes, may enter probe trade
AUTODUCK_IDLE_AI_PROBE_ENABLED=false
AUTODUCK_IDLE_AI_PROBE_MIN_SCORE=78
AUTODUCK_IDLE_AI_PROBE_SIZE_MULT=0.45

# true = idle probe may go LIVE (keep false for safety)
AUTODUCK_IDLE_AI_PROBE_LIVE=false

# ╔══════════════════════════════════════════════════════════════╗
# ║           AUTODUCK — CONTEXT / BIAS / QUALITY GATES            ║
# ╚══════════════════════════════════════════════════════════════╝
# VN market sentiment influence on crypto decisions (0 = more isolated)
AUTODUCK_CRYPTO_VN_BREADTH_BLEND=0.08
AUTODUCK_CRYPTO_VN_CROSS_BIAS=true
AUTODUCK_CONTEXT_BIAS_MAX=6

AUTODUCK_LIVE_QUALITY_MIN=82
AUTODUCK_SIM_QUALITY_MIN=72
AUTODUCK_LIVE_CONFLUENCE_MIN=3
AUTODUCK_LIVE_EDGE_MIN=28

# Per-setup quality (defaults to AUTODUCK_LIVE_QUALITY_MIN if unset)
# AUTODUCK_LIVE_MIN_QUALITY_EMA_PULLBACK=80
# AUTODUCK_LIVE_MIN_QUALITY_VWAP_RECLAIM=82

# ╔══════════════════════════════════════════════════════════════╗
# ║              AUTODUCK — SHORT LIVE / FILL POLLING            ║
# ╚══════════════════════════════════════════════════════════════╝
# Allow SHORT_CONTINUATION setup in LIVE whitelist (not "continuous macro short")
AUTODUCK_LIVE_ALLOW_SHORT_CONTINUATION=false
AUTODUCK_LIVE_ALLOW_SHORT_FALLBACK=false
# AUTODUCK_LIVE_MIN_QUALITY_SHORT_CONTINUATION=82
# AUTODUCK_LIVE_MIN_QUALITY_SHORT=84

# Fallback if DB Setting autoFuturesShortEnabled is not set
AUTODUCK_AUTO_FUTURES_SHORT_ENABLED=false

AUTODUCK_LIVE_FILL_POLL_MS=2000
AUTODUCK_LIVE_FILL_TIMEOUT_MS=25000

# ╔══════════════════════════════════════════════════════════════╗
# ║                    AUTODUCK — AUDIT LOGS                     ║
# ╚══════════════════════════════════════════════════════════════╝
AUTODUCK_AUDIT_ENABLED=true
AUTODUCK_AUDIT_LOG_DIR=logs/autoduck
AUTODUCK_AUDIT_ENCRYPT=false
# If AUTODUCK_AUDIT_ENCRYPT=true: use this key (64 hex) or fallback ENCRYPTION_KEY
# AUTODUCK_AUDIT_ENCRYPTION_KEY=

# Testnet symbol cache from exchangeInfo (ms), 21600000 = 6 hours
TESTNET_SYMBOL_CACHE_MS=21600000
