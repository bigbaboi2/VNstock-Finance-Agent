# ╔══════════════════════════════════════════════════════════════╗
# ║               OMNI DUCK — ENVIRONMENT VARIABLES              ║
# ║                    (Template / .env.example.en)              ║
# ║              Vietnamese version: .env.example                ║
# ║                  DO NOT commit .env to git                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ╔══════════════════════════════════════════════════════════════╗
# ║                  APP / DATABASE / TUNNEL                     ║
# ╚══════════════════════════════════════════════════════════════╝
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/omniduck

# ┌─ Public tunnel URL (only one tunnel active at a time) ────────┐
# │ PC (ngrok reserved domain):                                   │
# │   NGROK_DOMAIN=your-name.ngrok-free.dev                       │
# │   VITE_API_BASE_URL / WEBHOOK_BASE_URL = https://<domain>     │
# │   npm run dev:tunnel                                          │
# │                                                               │
# │ Termux / PC fallback (Cloudflare Quick Tunnel):               │
# │   npm run dev:tunnel:cf   → copy *.trycloudflare.com URL      │
# │   set VITE_API_BASE_URL + WEBHOOK_BASE_URL to that URL        │
# │   then re-register the Telegram webhook                       │
# │                                                               │
# │ SSH reverse (Termux → VPS with a fixed domain):               │
# │   ssh -R 3001:localhost:3001 user@vps                         │
# │   WEBHOOK_BASE_URL=https://your-vps-domain                    │
# └───────────────────────────────────────────────────────────────┘
NGROK_DOMAIN=your-name.ngrok-free.dev
VITE_API_BASE_URL=https://your-name.ngrok-free.dev
WEBHOOK_BASE_URL=https://your-name.ngrok-free.dev

APP_URL=http://localhost:3001
# Frontend (Telegram deep links) — defaults to Vercel production
FRONTEND_URL=https://your-frontend.example.com
AI_REPORT_CACHE_TTL_MS=5400000

# Node.js 24+ on Windows: if MongoDB SSL fails, use node --use-system-ca
# (npm run dev:backend is already configured)

# ╔══════════════════════════════════════════════════════════════╗
# ║                      ADMIN / SECURITY                        ║
# ╚══════════════════════════════════════════════════════════════╝
# Protects AI provider reset endpoint (blank = no key needed for local dev)
ADMIN_RESET_KEY=your_admin_reset_key

# Admin code for sensitive routes (audit-file-tail, ...)
ADMIN_CODE=your_admin_code_here

# Secret for external signal webhook (POST /api/external-signal)
EXTERNAL_SIGNAL_SECRET=your_strong_secret_here

# 64 hex chars (= 32 bytes) for AES-256-GCM
# Encrypts user exchange API keys + audit logs (when enabled)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ╔══════════════════════════════════════════════════════════════╗
# ║                       AI PROVIDERS                           ║
# ╚══════════════════════════════════════════════════════════════╝
# Gemini fallback chain: GEMINI_API_KEY_MAIN -> GEMINI_API_KEY -> API_KEY
GEMINI_API_KEY_MAIN=AIza...
GEMINI_API_KEY_ACTION=
GEMINI_API_KEY_INSIGHT=

MISTRAL_API_KEY=
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk-...
SAMBANOVA_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-...
DEEPINFRA_API_KEY=

# Optional — local DS2API (not recommended for production)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=http://127.0.0.1:5001/v1

# ╔══════════════════════════════════════════════════════════════╗
# ║                    MARKET DATA PROVIDERS                     ║
# ╚══════════════════════════════════════════════════════════════╝
COINGECKO_API_KEY=
COINGLASS_API_KEY=
FIREANT_TOKEN=your_fireant_token_here

# ╔══════════════════════════════════════════════════════════════╗
# ║                         TELEGRAM                             ║
# ╚══════════════════════════════════════════════════════════════╝
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ╔══════════════════════════════════════════════════════════════╗
# ║            FRONTEND (Vite — read via import.meta.env)        ║
# ╚══════════════════════════════════════════════════════════════╝
VITE_AI_PRICE_SIGNIFICANT_THRESHOLD=0.015
VITE_AI_NEWS_SIGNIFICANT_COUNT_THRESHOLD=3

# ╔══════════════════════════════════════════════════════════════╗
# ║        VN STOCK — NEWS PREFETCH (cron + tab cache)           ║
# ╚══════════════════════════════════════════════════════════════╝
# Background cron fetches headlines + sentiment for ~60 AutoDuck universe symbols.
# Speeds up VN analysis tab + keeps deepNewsData warm for AutoDuck.
# Lightweight fetch only (fast mode, no full article scrape) to avoid Google/RSS rate limits.
# Schedule: every 30 min (Mon–Fri) · every 6 h (Sat–Sun). Force refresh: ?force=true on /api/news/:ticker

# Enable/disable prefetch cron (set false to turn off)
VN_NEWS_PREFETCH_ENABLED=true

# DB news cache TTL — while fresh, /api/news/:ticker serves from DB immediately
# VN session: pre-market, ATO, regular hours, ATC (ms). Default 1 hour.
VN_NEWS_CACHE_TTL_SESSION_MS=3600000
# Off-session + weekends (ms). Default 6 hours.
VN_NEWS_CACHE_TTL_OFF_MS=21600000

# Per cron run limits (staggered to avoid burst / IP blocks)
VN_NEWS_PREFETCH_MAX_PER_RUN=10
VN_NEWS_PREFETCH_CONCURRENCY=2
VN_NEWS_PREFETCH_DELAY_MS=4000
# Universe size (same buildVnStockScanUniverse source as AutoDuck)
VN_NEWS_PREFETCH_UNIVERSE_LIMIT=60

# ╔══════════════════════════════════════════════════════════════╗
# ║              AUTODUCK — UI-managed (Auto Duck tab)           ║
# ╚══════════════════════════════════════════════════════════════╝
# Defaults: code · overrides: MongoDB Setting · leftover .env still read until UI Save.
